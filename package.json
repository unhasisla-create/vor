{
  "name": "vor-system",
  "version": "1.0.0",
  "description": "Vehicle Operational Report System — Dynamic Oasis v4.3",
  "private": true,
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "scripts": {
    "dev": "next dev",
    "dev:safe": "powershell -ExecutionPolicy Bypass -File start-dev.ps1",
    "start": "next start",
    "dev:fast": "node --max-old-space-size=4096 node_modules/.bin/next dev",
    "dev:turbo": "next dev --turbo",
    "build": "NODE_OPTIONS=\"--max-old-space-size=4096\" next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "prisma:generate": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "2.4.3",
    "clsx": "2.1.1",
    "date-fns": "3.6.0",
    "jsonwebtoken": "9.0.2",
    "lucide-react": "0.383.0",
    "next": "14.2.3",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "recharts": "2.12.7",
    "xlsx": "^0.18.5",
    "zustand": "4.5.2"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "9.0.2",
    "@types/node": "20.14.2",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "autoprefixer": "10.4.19",
    "eslint": "8.57.0",
    "eslint-config-next": "14.2.3",
    "postcss": "8.4.38",
    "prisma": "5.22.0",
    "tailwindcss": "3.4.4",
    "typescript": "5.5.2"
  }
}
