generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Branch {
  id        String     @id @default(uuid())
  name      String
  code      String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  isActive  Boolean    @default(true)
  users     User[]
  vehicles  Vehicle[]
  drivers   Driver[]
  customers Customer[]
}

model Customer {
  id             String    @id @default(uuid())
  code           String    @unique
  name           String
  branchId       String?
  isActive       Boolean   @default(true)
  inactiveReason String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  vehicles       Vehicle[]
  branch         Branch?   @relation(fields: [branchId], references: [id])

  @@index([branchId])
}

model Driver {
  id             String    @id @default(uuid())
  code           String    @unique
  name           String
  phone          String?
  branchId       String?
  isActive       Boolean   @default(true)
  inactiveReason String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  branch         Branch?   @relation(fields: [branchId], references: [id])
  vehicles       Vehicle[]

  @@index([branchId])
}

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String
  name         String
  role         Role
  branchId     String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  branch       Branch?  @relation(fields: [branchId], references: [id])
}

model Vehicle {
  id             Int                 @id @default(autoincrement())
  nopol          String              @unique
  type           String
  tonase         Float
  kubikasi       Float
  chassisNumber  String?
  revenueTarget  Float               @default(0)
  customerId     String?
  driverId       String?
  branchId       String
  isActive       Boolean             @default(true)
  inactiveReason String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  actuals        ActualOperation[]
  forecasts      ForecastOperation[]
  branch         Branch              @relation(fields: [branchId], references: [id])
  customerMaster Customer?           @relation(fields: [customerId], references: [id])
  driverMaster   Driver?             @relation(fields: [driverId], references: [id])

  @@index([branchId])
  @@index([customerId])
  @@index([driverId])
}

model ActualOperation {
  id        String   @id @default(uuid())
  vehicleId Int
  date      String
  status    String
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@unique([vehicleId, date])
}

model ForecastOperation {
  id         String   @id @default(uuid())
  vehicleId  Int
  date       String
  status     String
  confidence String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  vehicle    Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@unique([vehicleId, date])
}

model AuditLog {
  id     String   @id @default(uuid())
  ts     DateTime @default(now())
  user   String
  action String
  detail String
}

enum Role {
  ADMIN
  PLANNER
  SUPERVISOR
  MANAGEMENT
}

model RevenueRecord {
  id            String   @id @default(uuid())
  date          String
  branchId      String
  nopol         String
  typeUnit      String
  targetPerUnit Float    @default(0)
  achRevenue    Float    @default(0)
  bop           Float    @default(0) // Biaya Operasional (manual input)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([date, branchId, nopol])
}

model StatusConfig {
  code          String   @id
  desc          String
  group         String
  color         String
  details       String?
  isForecast    Boolean  @default(true)
  sortOrder     Int      @default(0)
  isActive      Boolean  @default(true)
  isPA      Boolean  @default(false)
  isUA      Boolean  @default(false)
  isPROD    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model KpiConfig {
  id            String   @id @default(uuid())
  metric        String   @unique
  label         String
  goodThreshold Float    @default(90)
  warnThreshold Float    @default(75)
  isActive      Boolean  @default(true)
  updatedAt     DateTime @updatedAt
}

model VehicleType {
  id             String    @id @default(uuid())
  code           String    @unique
  name           String
  isActive       Boolean   @default(true)
  inactiveReason String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}
