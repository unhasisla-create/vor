# VOR System — Environment Variables
# Copy file ini menjadi .env.local dan isi nilainya

# ── Supabase (opsional, untuk koneksi database production) ───────────────────
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# ── Database / Auth ─────────────────────────────────────────────────────────
# DATABASE_URL="postgresql://user:password@localhost:5432/vor_system"
# JWT_SECRET="replace-with-a-strong-secret"
# ── App Config ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="VOR System"
NEXT_PUBLIC_APP_VERSION="4.3"
NEXT_PUBLIC_TIMEZONE="Asia/Makassar"
